pipeline {
    agent any

    options {
        timestamps()
    }

    parameters {
        choice(name: 'TARGET_ENV', choices: ['staging', 'production'], description: 'staging ejecuta CI sobre develop; production ejecuta CD sobre master.')
    }

    environment {
        APP_REPO_URL = 'https://github.com/ovejabalvin/todo-list-aws.git'
        CONFIG_REPO_URL = 'https://github.com/ovejabalvin/todo-list-aws-config.git'
        AWS_REGION = 'us-east-1'
    }

    stages {
        stage('Resolve Environment') {
            steps {
                script {
                    env.SOURCE_BRANCH = params.TARGET_ENV == 'production' ? 'master' : 'develop'
                    env.CONFIG_BRANCH = params.TARGET_ENV == 'production' ? 'production' : 'staging'
                    env.SAM_ENV = params.TARGET_ENV
                    env.STACK_NAME = params.TARGET_ENV == 'production' ? 'todo-list-aws-production' : 'todo-list-aws-staging'
                    env.INTEGRATION_TEST = params.TARGET_ENV == 'production' ? 'test/integration/todoApiReadOnlyTest.py' : 'test/integration/todoApiTest.py'
                    env.JUNIT_FILE = params.TARGET_ENV == 'production' ? 'reports/pytest-read-only.xml' : 'reports/pytest-integration.xml'
                    env.TEST_LOG = params.TARGET_ENV == 'production' ? 'reports/pytest-read-only.log' : 'reports/pytest-integration.log'
                }
                sh '''
                    set -eu
                    echo "TARGET_ENV=$TARGET_ENV"
                    echo "SOURCE_BRANCH=$SOURCE_BRANCH"
                    echo "CONFIG_BRANCH=$CONFIG_BRANCH"
                    echo "Nodo por defecto: $(hostname)"
                    echo "Usuario por defecto: $(whoami)"
                '''
            }
        }

        stage('Get Code') {
            steps {
                checkout([$class: 'GitSCM',
                    branches: [[name: "*/${env.SOURCE_BRANCH}"]],
                    userRemoteConfigs: [[url: env.APP_REPO_URL]]
                ])
                sh '''
                    set -eu
                    rm -rf .cp-config reports
                    mkdir -p reports
                    git clone --depth 1 --branch "$CONFIG_BRANCH" "$CONFIG_REPO_URL" .cp-config
                    cp .cp-config/samconfig.toml samconfig.toml
                    test -f samconfig.toml
                    echo "Codigo: $SOURCE_BRANCH" | tee reports/pipeline-context.txt
                    echo "Config: $CONFIG_BRANCH" | tee -a reports/pipeline-context.txt
                    echo "Nodo Get Code: $(hostname)" | tee -a reports/pipeline-context.txt
                    echo "Usuario Get Code: $(whoami)" | tee -a reports/pipeline-context.txt
                '''
                stash name: 'source', includes: 'src/*,test/*,pytest.ini,template.yaml,requirements-dev.txt,samconfig.toml'
            }
        }

        stage('Static Test') {
            when {
                expression { env.TARGET_ENV == 'staging' }
            }
            agent {
                label 'static'
            }
            steps {
                deleteDir()
                unstash 'source'
                sh '''
                    set -eu
                    echo "Nodo Static Test: $(hostname)"
                    echo "Usuario Static Test: $(whoami)"
                    mkdir -p reports
                    rm -rf .venv
                    python3 -m venv .venv
                    . .venv/bin/activate
                    python -m pip install --upgrade pip
                    python -m pip install -r requirements-dev.txt
                    flake8 src --count --statistics --output-file=reports/flake8.txt || true
                    bandit -r src -f txt -o reports/bandit.txt || true
                    bandit -r src -f html -o reports/bandit.html || true
                    test -f reports/flake8.txt
                    test -f reports/bandit.txt
                    test -f reports/bandit.html
                '''
                stash name: 'static-reports', includes: 'reports/flake8.txt,reports/bandit.txt,reports/bandit.html'
            }
        }

        stage('Deploy') {
            steps {
                script {
                    if (env.TARGET_ENV == 'staging') {
                        unstash 'static-reports'
                    }
                }
                sh '''
                    set -eu
                    echo "Nodo Deploy: $(hostname)"
                    echo "Usuario Deploy: $(whoami)"
                    sam validate --region "$AWS_REGION"
                    sam build
                    sam deploy --config-env "$SAM_ENV" --no-confirm-changeset --no-fail-on-empty-changeset

                    aws cloudformation describe-stacks \
                        --stack-name "$STACK_NAME" \
                        --region "$AWS_REGION" \
                        --output json > reports/stack.json

                    python3 - <<'PY'
import json

with open("reports/stack.json") as f:
    data = json.load(f)

outputs = data["Stacks"][0].get("Outputs", [])
for output in outputs:
    if output.get("OutputKey") == "BaseUrlApi":
        with open("reports/base_url.txt", "w") as f:
            f.write(output["OutputValue"] + "\\n")
        break
else:
    raise SystemExit("No se encontro el output BaseUrlApi")
PY

                    cat reports/base_url.txt
                    test -s reports/base_url.txt
                '''
                stash name: 'rest-input', includes: 'src/*,test/*,pytest.ini,requirements-dev.txt,src/requirements.txt,reports/base_url.txt'
            }
        }

        stage('Rest Test') {
            agent {
                label 'rest'
            }
            steps {
                deleteDir()
                unstash 'rest-input'
                sh '''
                    set -eu
                    echo "Nodo Rest Test: $(hostname)"
                    echo "Usuario Rest Test: $(whoami)"
                    rm -rf .venv
                    python3 -m venv .venv
                    . .venv/bin/activate
                    python -m pip install --upgrade pip
                    python -m pip install -r requirements-dev.txt
                    python -m pip install -r src/requirements.txt
                    export BASE_URL="$(cat reports/base_url.txt)"
                    echo "BASE_URL=$BASE_URL"
                    set +e
                    pytest -q "$INTEGRATION_TEST" --junitxml="$JUNIT_FILE" > "$TEST_LOG" 2>&1
                    status=$?
                    set -e
                    cat "$TEST_LOG"
                    exit $status
                '''
                stash name: 'rest-reports', includes: 'reports/*/'
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'reports/*.xml'
                    archiveArtifacts artifacts: 'reports/*/', allowEmptyArchive: true
                }
            }
        }

        stage('Promote') {
            steps {
                sh '''
                    set -eu
                    git config user.email "jenkins@example.local"
                    git config user.name "Jenkins CI"
                    git fetch origin master develop
                    git checkout master
                    git merge --no-edit origin/develop
                    echo "Promocion local completada. Para subir a GitHub ejecutar manualmente: git push origin master"
                '''
            }
        }

    post {
        always {
            script {
                try {
                    unstash 'rest-reports'
                } catch (ignored) {
                    echo 'No hay informes REST para recuperar en este nodo.'
                }
            }
            archiveArtifacts artifacts: 'reports/*/', allowEmptyArchive: true
        }
    }
}